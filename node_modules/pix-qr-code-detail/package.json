{
  "name": "pix-qr-code-detail",
  "version": "1.2.0",
  "description": "Inspeciona BR Codes Pix dinamicos, extrai URL de payload e decodifica JWT.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/clean.cjs && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.cjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "Pix",
    "BRCode",
    "Efí Bank",
    "Detalhar Pix"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/efipay/pix-qr-code-detail.git"
  },
  "bugs": {
    "url": "https://github.com/efipay/pix-qr-code-detail/issues"
  },
  "homepage": "https://github.com/efipay/pix-qr-code-detail#readme",
  "author": "João Lucas Alberto Muniz",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}